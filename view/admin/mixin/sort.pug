mixin sort
    div(
        class="sort-select"
        sort
    )
        select(
            class = "form-control",
            name="sort"
            sort-select
        )
            option(value="" selected) -- Chọn tiêu chí sắp xếp
            option(value="price-desc") Giá giảm dần
            option(value="price-asc") Giá tăng dần
            option(value="rating-desc") Đánh giá giảm dần 
            option(value="rating-asc") Đánh giá tăng dần
            option(value="name-asc") Tiêu đề A - Z
            option(value="name-desc") Tiêu đề Z - A
        button(
            class = "btn btn-danger mt-2",
            sort-clear
        ) Clear 
mixin sortRole
