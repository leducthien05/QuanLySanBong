extends ../../layout/default.pug

block content
    .create-field-page
        .add-field-wrapper

            // Header
            .page-header
                p Điền đầy đủ thông tin để hiển thị sân trên hệ thống

            // Stepper
            .stepper
                div(
                    class="step active"
                    number-step = "step1"
                )
                    .step-number 1
                    .step-text
                        .step-title Thông tin cơ bản

                div(
                    class="step"
                    number-step = "step2"
                )
                    .step-number 2
                    .step-text
                        .step-title Hình ảnh & Tiện ích

            .main-content
                .info-card
                    .card-body
                        
                        form(
                            id="form-step1"
                            enctype="multipart/form-data"
                            method="POST"
                            aciton=`${prefixAdmin}/fields/create`
                        )
                            .div-step1
                                .card-header
                                    img(
                                        src="https://img.icons8.com/ios-filled/50/9fff57/stadium.png"
                                        width="28"
                                        alt=""
                                    )
                                    div
                                        h5 Thông tin cơ bản
                                        small Tên, địa chỉ và mô tả sân bóng
                                .form-group
                                    label
                                        | TÊN SÂN BÓNG
                                        span.required *
                                    input(
                                        type="text"
                                        id="tenSan"
                                        name="name"
                                        placeholder="Ví dụ: Sân Cầu Giấy FC"
                                        required
                                    )

                                .row.g-3
                                    .col-md-6
                                        .form-group
                                            label
                                                | LOẠI SÂN
                                                span.required *
                                            select(id="loaiSan" required name="type")
                                                option(value="" disabled selected) Chọn loại sân
                                                option(value="5") Sân 5 người
                                                option(value="7") Sân 7 người
                                                option(value="11") Sân 11 người

                                    .col-md-6
                                        .form-group
                                            label GIÁ THUÊ / GIỜ (VND)
                                            input(
                                                type="number"
                                                id="giaThue"
                                                name="price"
                                                placeholder="350000"
                                            )
                                    .col-md-6
                                        .form-group
                                            label GIÁ THUÊ VIP / GIỜ (VND)
                                            input(
                                                type="number"
                                                id="giaThue"
                                                name="priceVip"
                                                placeholder="400000"
                                            )
                                    .col-md-6
                                        .form-group
                                            label KÍCH THƯỚC
                                            input(
                                                type="texxt"
                                                id="giaThue"
                                                name="size"
                                                placeholder="50X60"
                                            )
                                    .col-md-6
                                        .form-group
                                            label LOẠI CỎ
                                            input(
                                                type="text"
                                                id="giaThue"
                                                name="grasstype"
                                                placeholder="Nhân tạo/ Tự nhiên"
                                            )
                                    .col-md-6
                                        .form-group
                                            label GIỜ HOẠT ĐỘNG
                                            input(
                                                type="text"
                                                id="giaThue"
                                                name="timeactive"
                                                placeholder="06:00-22:00"
                                            )
                                .form-group
                                    label
                                        | ĐỊA CHỈ CHI TIẾT
                                        span.required *
                                    input(
                                        type="text"
                                        name="titleAddress"
                                        placeholder="123 Đường ABC, Phường X, Quận Y"
                                        required
                                    )
                                .form-group
                                    label
                                        | ĐƯỜNG DẪN BẢN ĐỒ
                                        span.required *
                                    input(
                                        type="text"
                                        id="diaChi"
                                        name="googleMapUrl"
                                        placeholder="123 Đường ABC, Phường X, Quận Y"
                                        required
                                    )
                                .form-group
                                    label MÔ TẢ SÂN
                                    textarea(
                                        id="moTa"
                                        rows="4"
                                        name="description"
                                        placeholder="Mô tả thêm về sân..."
                                    )
                                .form-group
                                    label
                                        | VỊ TRÍ
                                    input(
                                        type="text"
                                        id="viTri"
                                        name="position"
                                        placeholder="1"
                                    )
                            .div-step2
                                .row.g-4
                                    // upload image - 6 phần
                                    .col-lg-7
                                        .upload-card
                                            .upload-header
                                                .upload-icon
                                                    i(class="fa fa-camera")
                                                .upload-info
                                                    h3 Hình ảnh sân bóng
                                                    p Tối đa 8 ảnh, định dạng JPG/PNG, tối đa 5MB/ảnh

                                            .upload-body
                                                label.upload-box(for="image")
                                                    i(class="fa fa-image upload-main-icon")
                                                    input(
                                                        type="file"
                                                        id="image"
                                                        multiple
                                                        name="image"
                                                        hidden
                                                    )

                                    // trạng thái - 4 phần
                                    .col-lg-5
                                        .publish-card
                                            .publish-header
                                                .publish-icon
                                                    i(class="fa fa-traffic-light")
                                                h3 Trạng thái đăng

                                            .publish-body
                                                label.status-option.active
                                                    .status-left
                                                        span.dot.green
                                                        .status-info
                                                            h4 Mở cửa ngay
                                                            p Nhận đặt sân ngay sau khi đăng
                                                    input(type="radio" name="status" value="active" checked)

                                                label.status-option
                                                    .status-left
                                                        span.dot.yellow
                                                        .status-info
                                                            h4 Đang chuẩn bị
                                                            p Hiển thị nhưng chưa nhận đặt
                                                    input(type="radio" name="status" value="inactive")
                                            .publish-body
                                                label.status-option.active
                                                    .status-left
                                                        span.dot.green
                                                        .status-info
                                                            h4 Sân nổi bật
                                                            p Sân có doanh thu cao sẽ được đề xuất nhiều hơn
                                                    input(type="radio" name="feature" value="1")
                                .service-box
                                    .service-header
                                        .service-icon ✨
                                        div
                                            h2 Tiện ích & Dịch vụ
                                            p Chọn các tiện ích có tại sân

                                    .service-list
                                        each item in ["💡 Đèn cao áp","🏠 Có mái che","🧥 Phòng thay đồ","🚗 Bãi giữ xe","☕ Căng tin","📹 Camera an ninh","⚽ Cho thuê bóng","👟 Cho thuê giày","🛁 Phòng tắm","📶 Wi-Fi miễn phí","🩹 Tủ thuốc sơ cứu","🎵 Loa âm thanh"]
                                            label.service-item
                                                input(type="checkbox" name="service" value=item)
                                                span #{item}
                            // footer submit
                            .form-footer
                                button(type="button" class="btn-back") Quay lại
                                button(type="submit" class="btn-submit") Tạo sân bóng
    script(src="/admin/JS/script.js") 