extends ../../layout/default.pug

block content
    .create-field-page
        .add-field-wrapper

            // Header
            .page-header
                p Điền đầy đủ thông tin để hiển thị sân trên hệ thống

            // Stepper
            .stepper
                div(
                    class="step active"
                    number-step = "step1"
                )
                    .step-number 1
                    .step-text
                        .step-title Thông tin cơ bản

                div(
                    class="step"
                    number-step = "step2"
                )
                    .step-number 2
                    .step-text
                        .step-title Hình ảnh & Tiện ích
                div(
                    class="step"
                    number-step = "step3"
                )
                    .step-number 3
                    .step-text
                        .step-title Lịch hoạt động

            .main-content
                .info-card
                    .card-body
                        
                        form(
                            id="form-step1"
                            enctype="multipart/form-data"
                            method="POST"
                            aciton=`${prefixAdmin}/fields/create`
                        )
                            .div-step1
                                .card-header
                                    img(
                                        src="https://img.icons8.com/ios-filled/50/9fff57/stadium.png"
                                        width="28"
                                        alt=""
                                    )
                                    div
                                        h5 Thông tin cơ bản
                                        small Tên, địa chỉ và mô tả sân bóng
                                .form-group
                                    label
                                        | TÊN SÂN BÓNG
                                        span.required *
                                    input(
                                        type="text"
                                        id="tenSan"
                                        name="name"
                                        placeholder="Ví dụ: Sân Cầu Giấy FC"
                                        required
                                    )

                                .row.g-3
                                    .col-md-6
                                        .form-group
                                            label
                                                | LOẠI SÂN
                                                span.required *
                                            select(id="loaiSan" required name="type")
                                                option(value="" disabled selected) Chọn loại sân
                                                option(value="5") Sân 5 người
                                                option(value="7") Sân 7 người
                                                option(value="11") Sân 11 người

                                    .col-md-6
                                        .form-group
                                            label GIÁ THUÊ / GIỜ (VND)
                                            input(
                                                type="number"
                                                id="giaThue"
                                                name="price"
                                                placeholder="350000"
                                            )

                                .form-group
                                    label
                                        | ĐỊA CHỈ CHI TIẾT
                                        span.required *
                                    input(
                                        type="text"
                                        name="titleAddress"
                                        placeholder="123 Đường ABC, Phường X, Quận Y"
                                        required
                                    )
                                .form-group
                                    label
                                        | ĐƯỜNG DẪN BẢN ĐỒ
                                        span.required *
                                    input(
                                        type="text"
                                        id="diaChi"
                                        name="googleMapUrl"
                                        placeholder="123 Đường ABC, Phường X, Quận Y"
                                        required
                                    )
                                .form-group
                                    label MÔ TẢ SÂN
                                    textarea(
                                        id="moTa"
                                        rows="4"
                                        name="description"
                                        placeholder="Mô tả thêm về sân..."
                                    )
                            .div-step2
                                .row.g-4
                                    // upload image - 6 phần
                                    .col-lg-7
                                        .upload-card
                                            .upload-header
                                                .upload-icon
                                                    i(class="fa fa-camera")
                                                .upload-info
                                                    h3 Hình ảnh sân bóng
                                                    p Tối đa 8 ảnh, định dạng JPG/PNG, tối đa 5MB/ảnh

                                            .upload-body
                                                label.upload-box(for="image")
                                                    i(class="fa fa-image upload-main-icon")
                                                    input(
                                                        type="file"
                                                        id="image"
                                                        multiple
                                                        name="image"
                                                        hidden
                                                    )

                                    // trạng thái - 4 phần
                                    .col-lg-5
                                        .publish-card
                                            .publish-header
                                                .publish-icon
                                                    i(class="fa fa-traffic-light")
                                                h3 Trạng thái đăng

                                            .publish-body
                                                label.status-option.active
                                                    .status-left
                                                        span.dot.green
                                                        .status-info
                                                            h4 Mở cửa ngay
                                                            p Nhận đặt sân ngay sau khi đăng
                                                    input(type="radio" name="status" value="active" checked)

                                                label.status-option
                                                    .status-left
                                                        span.dot.yellow
                                                        .status-info
                                                            h4 Đang chuẩn bị
                                                            p Hiển thị nhưng chưa nhận đặt
                                                    input(type="radio" name="status" value="inactive")
                            .div-step3
                                .schedule-card
                                    .schedule-header
                                        .schedule-icon
                                            i.fa.fa-calendar
                                        .schedule-info
                                            h3 Lịch hoạt động
                                            p Chọn khung giờ khách có thể đặt sân

                                    .schedule-body
                                        table.schedule-table
                                            thead
                                                tr
                                                    th Giờ
                                                    th T2
                                                    th T3
                                                    th T4
                                                    th T5
                                                    th T6
                                                    th T7
                                                    th CN

                                            tbody
                                                each time in ['06:00','07:00','08:00','09:00','10:00','11:00','12:00','13:00','14:00','15:00','16:00','17:00','18:00','19:00','20:00','21:00','22:00']
                                                    tr
                                                        td(class="time-label") #{time}

                                                        each day in ['mon','tue','wed','thu','fri','sat','sun']
                                                            td
                                                                label(class="slot-item")
                                                                    input(
                                                                        type="checkbox"
                                                                        name="schedule"
                                                                        value=`${day}-${time}`
                                                                        hidden
                                                                    )
                                                                    span(class="slot-box")
                            // footer submit
                            .form-footer
                                button(type="button" class="btn-back") Quay lại
                                button(type="submit" class="btn-submit") Tạo sân bóng
    script(src="/admin/JS/script.js") 