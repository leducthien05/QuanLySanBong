extends ../../layout/default
include ../../mixin/convertTime.pug

block content
    .sb-admin-dashboard

        //- // Header Filter
        //- .sb-admin-filter
        //-     .sb-admin-filter__left
        //-         span.sb-admin-filter__label Kỳ báo cáo:
        //-         button.sb-admin-filter__btn Hôm nay
        //-         button.sb-admin-filter__btn 7 ngày
        //-         button.sb-admin-filter__btn.active Tháng này
        //-         button.sb-admin-filter__btn Quý
        //-         button.sb-admin-filter__btn Năm
        //-         button.sb-admin-filter__btn Tùy chỉnh

        //-     .sb-admin-filter__right
        //-         label
        //-             input(type="checkbox")
        //-             | So sánh kỳ trước

        // Statistic Cards
        .sb-admin-stats

            .sb-admin-stat-card
                .sb-admin-stat-card__title DOANH THU THÁNG

                .sb-admin-stat-card__value
                    = (statistic.currentRevenue || 0).toLocaleString("vi-VN") + "đ"

                .sb-admin-stat-card__compare
                    = statistic.revenuePercent + "%"

            .sb-admin-stat-card
                .sb-admin-stat-card__title LƯỢT ĐẶT SÂN

                .sb-admin-stat-card__value
                    = statistic.bookingCount

            .sb-admin-stat-card
                .sb-admin-stat-card__title NGƯỜI DÙNG MỚI

                .sb-admin-stat-card__value
                    = statistic.newUsers

            .sb-admin-stat-card
                .sb-admin-stat-card__title GIÁ TRỊ TB/ĐƠN

                .sb-admin-stat-card__value
                    = statistic.avgOrderValue.toLocaleString("vi-VN") + "đ"

            .sb-admin-stat-card
                .sb-admin-stat-card__title TỈ LỆ HỦY

                .sb-admin-stat-card__value
                    = statistic.cancelRate + "%"

        // Main Content
        .sb-admin-content

            // Revenue Chart
            .sb-admin-chart-card

                .sb-admin-card-header
                    .sb-admin-card-title
                        i.fa-solid.fa-chart-line
                        span Biểu đồ doanh thu

                    .sb-admin-tab-group
                        button.active Doanh thu
                        button Đặt sân
                        button Người dùng

                .sb-admin-card-body

                    .sb-admin-chart-summary

                        .sb-admin-chart-summary__value
                            = statistic.currentRevenue.toLocaleString("vi-VN")

                        .sb-admin-chart-summary__text đ tổng tháng này

                        .sb-admin-chart-summary__compare
                            = statistic.revenuePercent + "%"

                    .sb-admin-chart-placeholder
                        canvas(
                            id="revenueChart"
                            data-chart=`${JSON.stringify(revenueChart)}`
                        )

            // Sidebar
            .sb-admin-sidebar

                .sb-admin-side-card

                    .sb-admin-card-header
                        .sb-admin-card-title
                            span Thể loại sân

                    .sb-admin-donut-wrapper

                        .sb-admin-donut-info

                            .sb-admin-donut-item
                                span Sân 5 người

                            .sb-admin-donut-item
                                span Sân 7 người

                            .sb-admin-donut-item
                                span Sân 11 người

        // Bottom
        .sb-admin-bottom

            .sb-admin-bottom-card

                .sb-admin-card-header
                    .sb-admin-card-title Doanh thu theo sân

                    a(href="#") Xuất PNG

                .sb-admin-card-body
                    .sb-admin-heatmap
                        if(topFields && topFields.length > 0)
                            each item,index in topFields
                                .sb-admin-ranking

                                    .sb-admin-ranking__name
                                        span #{index + 1}
                                        | #{item.field.name || "Không xác định"}

                                    .sb-admin-ranking__value
                                        = item.revenue.toLocaleString("vi-VN") + "đ"
            .sb-admin-bottom-card

                .sb-admin-card-header
                    .sb-admin-card-title Top sân có doanh thu

                    a(href="#") Xuất PNG

                .sb-admin-card-body
                    .sb-admin-heatmap
                        if(topFields && topFields.length > 0)
                            each item,index in topFields

                                .sb-admin-ranking

                                    .sb-admin-ranking__name
                                        span #{index + 1}
                                        | #{item.field.name || "Không xác định"}

                                    .sb-admin-ranking__value
                                        = item.revenue.toLocaleString("vi-VN") + "đ"

                                .sb-admin-ranking-bar
                                    .sb-admin-ranking-bar__fill(
                                        style=`width:${Math.min(item.revenue / topFields[0].revenue * 100,100)}%`
                                    )
                    
        // Revenue Analytics
        .sb-admin-revenue-extra
                        
            // Transaction Table
            .sb-admin-transaction

                .sb-admin-card-header

                    .sb-admin-card-title
                        span Chi tiết giao dịch

                    .sb-admin-table-tools

                        //- input(
                        //-     type="text"
                        //-     placeholder="Tìm giao dịch..."
                        //- )

                        //- select
                        //-     option Tất cả

                        //- select
                        //-     option Hôm nay

                .sb-admin-transaction__body

                    table.sb-admin-table

                        thead
                            tr
                                th Mã GD
                                th Khách hàng
                                th Sân bóng
                                th Thời gian
                                th Số tiền
                                th Hình thức
                                th Trạng thái

                        tbody

                            if(transactions && transactions.length > 0)

                                each item in transactions

                                    tr

                                        td
                                            | #TT-
                                            = item._id.toString().slice(-4)

                                        td
                                            if(item.user_id)
                                                = item.userInfo.userName
                                            else
                                                | Không xác định

                                        td
                                            if(item.field_id)
                                                = item.fieldInfo.name
                                            else
                                                | Không xác định

                                        td
                                            +date(item.createdAt)

                                        td
                                            = (item.totalPrice || 0).toLocaleString("vi-VN")
                                            | đ

                                        td
                                            span.sb-admin-badge.blue
                                                = item.paymentInfo.title || "MoMo"

                                        td

                                            if(item.status == "completed")

                                                span.sb-admin-badge.green
                                                    | Thành công

                                            else if(item.status == "canceled")

                                                span.sb-admin-badge.red
                                                    | Đã hủy

                                            else

                                                span.sb-admin-badge.yellow
                                                    = item.status

                                        

                            else

                                tr
                                    td(
                                        colspan="8"
                                        style="text-align:center"
                                    )
                                        | Chưa có giao dịch nào
    
block foolter    
    script(src="/admin/JS/revenue.js") 