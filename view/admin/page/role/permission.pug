extends ../../layout/default.pug

block content
    .permission-page
        form.permission-form(
            method="POST"
            action=`${prefixAdmin}/roles/permission?_method=PATCH`
            form-permission

        )
            div(
                class="form-group d-none"
                data-role-all = roles
            )
                input(
                    type="text"
                    class="form-control"
                    input-permission-form
                    name = "permission"
                )
            .permission-card

                //- Header
                .permission-header
                    .header-left
                        .header-icon
                            i.fa-solid.fa-user-shield
                        .header-content
                            h2 Ma trận quyền truy cập

                    .header-right
                        select(class="role-filter")
                            option Tất cả vai trò
                            each item in roles 
                                option(value = item._id) #{item.name}

                        if(accountRole.permission.includes("permission"))
                            button(
                                class="save-btn"
                                type="submit"
                            )
                                | Lưu thay đổi

                //- Table
                .permission-table-wrapper
                    table(class="permission-table")

                        thead
                            tr
                                th.permission-col QUYỀN HẠN  
                                each item in roles
                                    th
                                        .role-head
                                            span #{item.name}
                        tbody
                            tr(
                                data-role = "id"
                                class = "d-none"
                            ) 
                                    
                                each item in roles
                                    td(class="text-center")
                                        input(
                                           
                                            name="id"
                                            type="text"
                                            value = item.id
                                        )
                            //- Group title
                            tr.group-row
                                td(colspan="6")
                                    .group-title
                                        i.fa-regular.fa-futbol
                                        span QUẢN LÝ SÂN BÓNG

                            //- Row 1
                            tr(data-role="fields_view")
                                td.permission-name Xem danh sách sân
                                each item in roles
                                    td("fields_view")
                                        label.checkbox-custom
                                            input(
                                                type="checkbox"
                                            )
                                            span.checkmark

                            //- Row 2
                            tr(data-role="fields_create")
                                td.permission-name Thêm sân mới

                                each item in roles
                                    td("fields_create")
                                        label.checkbox-custom
                                            input(
                                                type="checkbox"
                                            )
                                            span.checkmark

                            //- Row 3
                            tr(data-role="fields_edit")
                                td.permission-name Chỉnh sửa thông tin sân

                                each item in roles
                                    td("fields_edit")
                                        label.checkbox-custom
                                            input(
                                                type="checkbox"
                                            )
                                            span.checkmark

                            //- Row 4
                            tr(data-role="fields_delete")
                                td.permission-name Xóa sân

                                each item in roles
                                    td("fields_delete")
                                        label.checkbox-custom
                                            input(
                                                type="checkbox"
                                            )
                                            span.checkmark

                            //- Row 5
                            tr(data-role="fields_status")
                                td.permission-name Đổi trạng thái sân

                                each item in roles
                                    td("fields_status")
                                        label.checkbox-custom
                                            input(
                                                type="checkbox"
                                            )
                                            span.checkmark
                            //- Group title
                            tr.group-row
                                td(colspan="6")
                                    .group-title
                                        i.fa-regular.fa-futbol
                                        span QUẢN LÝ LỊCH ĐẶT

                            //- Row 1
                            tr(data-role="bookings_view")
                                td.permission-name Xem danh sách lịch đặt
                                each item in roles
                                    td("bookings_view")
                                        label.checkbox-custom
                                            input(
                                                type="checkbox"
                                            )
                                            span.checkmark

                            //- Row 2
                            tr(data-role="bookings_create")
