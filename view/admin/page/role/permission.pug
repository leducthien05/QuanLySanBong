                                each item in roles
                                    td("services_create")
                                        label.checkbox-custom
                                            input(
                                                type="checkbox"
                                            )
                                            span.checkmark

                            //- Row 3
                            tr(data-role="roles_edit")
                                td.permission-name Chỉnh sửa nhóm quyền

