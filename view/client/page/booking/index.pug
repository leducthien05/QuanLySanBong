extends ../../layout/default.pug

block content

    main.booking-container

        //- HERO SECTION
        section.booking-hero
            .gf-container
                .booking-hero-content

                    //- Badge/Tag
                    .booking-hero-tag
                        span.booking-hero-tag-dot
                        | Đặt sân trực tuyến

                    //- Main Title
                    h1.booking-hero-title Đặt sân bóng

                    //- Subtitle
                    p.booking-hero-subtitle Hoàn thành các bước đơn giản – nhận xác nhận ngay lập tức
        // SEARCH
    section.gf-search
        .gf-container

            .gf-search-box

                .gf-search-grid

                    .gf-form-group
                        label Ngày đặt sân
                        input(
                            type="date"
                            name="date"
                        )

                    .gf-form-group
                        label Loại sân
                        select(name="type")
                            option(value="") Tất cả
                            option(value="5") Sân 5
                            option(value="7") Sân 7
                            option(value="11") Sân 11
                    .gf-form-group
                        label Vị trí
                        select(name="address")
                            option(value="") Tất cả
                            each item in address
                                option(value=item) #{item}
                .gf-form-group.search-field-group
                    label Tìm kiếm tên sân
                    input(
                        type="text"
                        name="fieldName"
                        placeholder="Nhập tên sân..."
                    )
                    .search-result.hidden
                        ul.search-result-list

        //- FIELD SELECTION SECTION
        section(class="booking-fields")
            .gf-container

                .booking-section-header
                    h2.booking-section-title Chọn Sân Bóng
                    span.booking-subtitle-text Các sân bóng khả dụng
                .booking-fields-grid
                    each item in fields
                        //- Field Card 1
                        div(
                            class="booking-field-card"
                            data-field-id=item._id 
                            data-field = item
                        )
                            .booking-field-image
                                img(
                                    src=item.image
                                )
                            
                            .booking-field-content
                                h3.booking-field-name #{item.name}
                                
                                .booking-field-type Loại: #{item.type}v#{item.capacity}
                                
                                .booking-field-location
                                    a(
                                        href=item.address.googleMapUrl
                                    )
                                    | 📍 #{item.address.titleAddress}
                                
                                //- .booking-field-rating
                                //-     span.booking-stars ⭐⭐⭐⭐⭐
                                //-     span.booking-rating-number (4.8)
                                
                                .booking-field-footer
                                    .booking-field-price
                                        span.booking-price-number #{item.price.price}
                                        span.booking-price-unit đ/giờ
                                    
                                    .booking-field-status.booking-field-status--available
                                        span Sẵn sàng
        .gf-container
            .booking-selected-time
                span.booking-selected-time-label Giờ đã chọn:
                span.booking-selected-time-value#selectedTimeText Chưa chọn khung giờ
        .gf-container
            section.booking-slots-grid
        
        //- SERVICES SECTION
        section.booking-services
            .gf-container

                .booking-section-header
                    h2.booking-section-title Dịch Vụ Bổ Sung
                    span.booking-subtitle-text Chọn dịch vụ bạn cần (tuỳ chọn)

                //- Services grid
                .booking-services-grid
                    each item in services
                        //- Service 1: Ball Rental
                        .booking-service-card(data-service-id=item._id)
                            .booking-service-icon 
                                img(
                                    src=item.image
                                    alt=item.name
                                )
                            
                            h3.booking-service-name #{item.name}
                            
                            .booking-service-description #{item.description}
                            
                            .booking-service-price #{item.price} đ
        section.booking-confirmation
            .gf-container
                .booking-section-header
                    h2.booking-section-title Xác nhận đặt sân
                    span.booking-subtitle-text Chọn phương thức thanh toán trước khi tiếp tục

                .booking-payment-grid
                    each item in payment
                        button.payment-method-card(type="button" data-payment-method=item._id)
                            .payment-method-card-main
                                span.payment-method-title #{item.title}
                                span.payment-method-subtitle #{item.description}
                            .payment-method-check
                .booking-action-row
                    button.booking-confirm-button(type="button") Tạo booking

        .booking-modal-overlay.hidden
            .booking-modal
                .booking-modal-header
                    h3 Xác nhận đặt sân
                    button.booking-modal-close(type="button") ×
                p.booking-modal-subtitle Vui lòng kiểm tra thông tin và tiến hành thanh toán.
                .booking-modal-info
                    .booking-modal-row
                        span.label Sân
                        span.value.booking-modal-field-name Chưa chọn
                    .booking-modal-row
                        span.label Địa điểm
                        span.value.booking-modal-field-location Chưa chọn
                    .booking-modal-row
                        span.label Loại sân
                        span.value.booking-modal-field-type Chưa chọn
                    .booking-modal-row
                        span.label Ngày
                        span.value.booking-modal-field-date Chưa chọn
                    .booking-modal-row
                        span.label Giờ
                        span.value.booking-modal-field-times Chưa chọn
                    .booking-modal-row
                        span.label Phương thức thanh toán 
                        span.value.booking-modal-field-payment Chưa chọn
                    .booking-modal-row
                        span.label Dịch vụ
                        span.value.booking-modal-field-service Chưa chọn
                .booking-modal-row.booking-modal-row-note
                    label(for="booking-note") Ghi chú

                    textarea(
                        id="booking-note"
                        class="booking-modal-note-input"
                        placeholder="Nhập ghi chú cho đơn đặt sân..."
                        rows="2"
                    )
                .booking-modal-total
                    span Tổng thanh toán
                    strong.booking-modal-total-amount 0 đ
                .booking-modal-actions
                    button.booking-modal-cancel(type="button") Hủy
                    button.booking-modal-pay(type="button") Thanh toán ngay


    form.booking-form.hidden(
        method="POST"
        action="/booking/payment"
    )

        .hidden
            input.hidden(
                type="text"
                name="bookingData"
            )

    .payment-success-modal-overlay.hidden
        .payment-success-modal
            .payment-success-icon
                svg(width="60" height="60" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg")
                    circle(cx="12" cy="12" r="11" stroke="#d3f6c8" stroke-width="2")
                    path(d="M7.5 12.5L10.5 15.5L16.5 9.5" stroke="#1b5e20" stroke-width="2" stroke-linecap="round" stroke-linejoin="round")
            h2.payment-success-title Booking Successful!
            p.payment-success-message Your booking has been confirmed and sent to your email.
            .payment-success-summary
                .payment-success-summary-row
                    span.summary-label Field name
                    span.summary-value.payment-success-field-name Chưa rõ
                .payment-success-summary-row
                    span.summary-label Location
                    span.summary-value.payment-success-field-location Chưa rõ
                .payment-success-summary-row
                    span.summary-label Date and time
                    span.summary-value.payment-success-field-datetime Chưa rõ
                .payment-success-summary-row
                    span.summary-label Total price
                    span.summary-value.payment-success-field-total Chưa rõ
            .payment-success-actions
                button.payment-success-home(type="button") Back to Home
                button.payment-success-close(type="button") Close

    script#paymentSuccessPayload(type="application/json") !{JSON.stringify(successData || {})}
    script(src="/client/JS/script.js")