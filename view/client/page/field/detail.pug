    section.field-review
        .gf-container

            h2.section-title
                span.line
                | Đánh giá từ khách hàng

            // Tổng quan
            .review-summary

                .summary-score
                    h3 4.9

                    .stars
                        | ⭐⭐⭐⭐⭐

                    p 128 đánh giá

                .summary-bars

                    .bar-row
                        span 5
                        .bar
                            .fill.star5(style="width:85%")
                        span 109

                    .bar-row
                        span 4
                        .bar
                            .fill.star4(style="width:12%")
                        span 14

                    .bar-row
                        span 3
                        .bar
                            .fill.star3(style="width:3%")
                        span 4

                    .bar-row
                        span 2
                        .bar
                            .fill.star2(style="width:1%")
                        span 1

                    .bar-row
                        span 1
                        .bar
                            .fill.star1(style="width:0%")
                        span 0

            // Form đánh giá

            .review-form-card

                h3 Viết đánh giá

                form

                    .rating-stars

                        each star in [5,4,3,2,1]
                            label.star-option
                                input(
                                    type="radio"
                                    name="rating"
                                    value=star
                                )
                                span #{star}★

                    .form-group
                        textarea(
                            rows="5"
                            placeholder="Chia sẻ trải nghiệm của bạn về sân bóng..."
                        )

                    button.btn-review-submit(type="button")
                        i.fa-solid.fa-paper-plane
                        |  Gửi đánh giá

            // Review mẫu

            .review-list

                .review-card

                    .review-header

                        .review-user

                            .review-avatar
                                | NA

                            .review-info
                                h4 Nguyễn Văn A
                                span 12/05/2026

                        .review-rating ⭐⭐⭐⭐⭐

                    p.review-content
                        | Sân rất tốt, cỏ mới, đèn sáng.
                        | Nhân viên nhiệt tình, giá cả hợp lý.
                        | Đặt sân qua app rất tiện, chỉ mất 2 phút là xong.
                        | Sẽ quay lại vào tuần sau!

                    .review-tags
                        span.review-tag Cỏ tốt
                        span.review-tag Nhân viên thân thiện
                        span.review-tag Đặt sân nhanh

                .review-card

                    .review-header

                        .review-user

                            .review-avatar
                                | TT

                            .review-info
                                h4 Trần Thành
                                span 08/05/2026

                        .review-rating ⭐⭐⭐⭐

                    p.review-content
                        | Sân sạch sẽ, bãi gửi xe rộng.
                        | Tuy nhiên cuối tuần khá đông nên cần đặt trước.

                    .review-tags
                        span.review-tag Sân đẹp
                        span.review-tag Bãi xe rộng

                .review-card

                    .review-header

                        .review-user

                            .review-avatar
                                | LM

                            .review-info
                                h4 Lê Minh
                                span 02/05/2026

                        .review-rating ⭐⭐⭐⭐⭐

                    p.review-content
                        | Chất lượng sân rất ổn, ánh sáng tốt.
                        | Giá hợp lý so với khu vực Cầu Giấy.

                    .review-tags
                        span.review-tag Giá hợp lý
                        span.review-tag Đèn sáng

    script(src="/client/JS/script.js")