extends ../../layout/default.pug

block content

    // HERO
    section.gf-hero
        .gf-container.gf-hero__grid

            .gf-hero__content

                .gf-hero__tag
                    span.gf-dot
                    | Đặt sân trong 60 giây

                h1.gf-hero__title
                    | Tìm & Đặt
                    br
                    span Sân Bóng
                    br
                    | Ngay Hôm Nay

                p.gf-hero__desc
                    | Hơn 50 sân bóng chất lượng cao tại Hà Nội.
                    | Đặt lịch dễ dàng, thanh toán nhanh chóng.

                .gf-hero__actions
                    button.gf-btn.gf-btn--primary
                        | Đặt sân ngay

                    button.gf-btn.gf-btn--outline
                        | Xem sân trống

                //- .gf-stats

                //-     .gf-stat
                //-         h3 50+
                //-         p Sân bóng

                //-     .gf-stat
                //-         h3 2K+
                //-         p Người dùng

                //-     .gf-stat
                //-         h3 98%
                //-         p Hài lòng

            .gf-hero__card

                .gf-hero__image
                    if(fields.length > 0)
                        img(src=fields[0].image alt="Sân bóng")

                .gf-hero__info

                    .gf-hero__meta
                        if(fields.length > 0)
                            h3 #{fields[0].name}
                        if(fields.length > 0)
                            p 
                                each item in fields[0].rating.totalRating
                                    |★
                                | (#{fields[0].rating.totalReviews} đánh giá)

                    span.gf-badge Còn trống

    // SEARCH
    section.gf-search
        .gf-container

            .gf-section-head
                h2
                    | Tìm
                    span  Sân Trống

            .gf-search-box

                .gf-search-grid

                    .gf-form-group
                        label Ngày đặt sân
                        input(type="date")

                    .gf-form-group
                        label Khu vực
                        select
                            option Tất cả khu vực
                            option Cầu Giấy
                            option Hoàn Kiếm
                            option Đống Đa
                            option Long Biên

                    .gf-form-group
                        label Loại sân
                        select
                            option Tất cả loại sân
                            option Sân 5 người
                            option Sân 7 người
                            option Sân 11 người

                    .gf-form-group
                        label Thời gian
                        select
                            option Bất kỳ
                            option Sáng
                            option Chiều
                            option Tối

                button.gf-search-btn
                    | Tìm kiếm sân

    // FIELD
    section.gf-fields
        .gf-container

            .gf-section-head.gf-section-head--between

                h2
                    | Sân Nổi
                    span  Bật

                a.gf-see-all(href="#")
                    | Xem tất cả →

            .gf-fields-grid

                each item in fields

                    .gf-field-card

                        .gf-field-thumb
                            img(src=item.image alt="Sân bóng")

                            .gf-field-tags
                                span Sân #{item.type}
                                span #{item.grasstype}

                            .gf-field-status
                                | Còn trống

                        .gf-field-body

                            h3 #{item.name}

                            p.gf-field-location
                                | 📍 #{item.address.titleAddress}

                            .gf-field-bottom

                                .gf-price
                                    | #{item.price.price.toLocaleString("vi-VN")}
                                    span  / giờ

                                button.gf-book-btn
                                    | Đặt ngay
    // SERVICES
    section.gf-service-slot

        .gf-container

            .gf-section-head

                h2.gf-section-title
                    | Dịch Vụ
                    span  Đi Kèm

                p.gf-section-desc
                    | Các tiện ích hỗ trợ dành cho người chơi tại GreenField.

            .gf-service-slot__grid

                each item in services

                    .gf-service-item

                        .gf-service-item__icon
                            if item.icon
                                img(
                                    src=item.image
                                    alt=item.name
                                )
                            else
                                span ⚽

                        .gf-service-item__title
                            | #{item.name}

                        .gf-service-item__desc
                            | #{item.description}

                        .gf-service-item__bottom

                            if item.price > 0

                                .gf-service-item__price
                                    | #{item.price.toLocaleString("vi-VN")}
                                    span đ

                            else

                                .gf-service-item__free
                                    | Miễn phí

    // SLOT
    section.gf-slots
        .gf-container

            .gf-section-head.gf-section-head--between

                h2
                    | Chọn
                    span  Khung Giờ

                a.gf-see-all(href="#")
                    | ← Quay lại

            .gf-slot-grid

                each item in ['06:00','07:00','08:00','09:00','10:00','11:00','13:00','14:00','15:00','16:00','17:00','18:00']

                    .gf-slot
                        h4= item
                        p 1 giờ

    // FOOTER SPACE
    .gf-space