extends ../../layout/default.pug

block content

    // HERO
    section.gf-hero
        .gf-container.gf-hero__grid

            .gf-hero__content

                .gf-hero__tag
                    span.gf-dot
                    | Đặt sân trong 60 giây

                h1.gf-hero__title
                    | Tìm & Đặt
                    br
                    span Sân Bóng
                    br
                    | Ngay Hôm Nay

                p.gf-hero__desc
                    | Hơn 50 sân bóng chất lượng cao tại Hà Nội.
                    | Đặt lịch dễ dàng, thanh toán nhanh chóng.

                .gf-hero__actions
                    button.gf-btn.gf-btn--primary
                        | Đặt sân ngay

                    button.gf-btn.gf-btn--outline
                        | Xem sân trống

                //- .gf-stats

                //-     .gf-stat
                //-         h3 50+
                //-         p Sân bóng

                //-     .gf-stat
                //-         h3 2K+
                //-         p Người dùng

                //-     .gf-stat
                //-         h3 98%
                //-         p Hài lòng

        // SECTION 1
        section.sb-home-featured

            .sb-home-container

                .sb-home-heading

                    span.sb-home-subtitle
                        | ── Sân nổi bật

                    h2
                        | Sân nổi bật
                        span  hôm nay

                    p
                        | Chọn từ hơn 50 sân được kiểm duyệt chất lượng

                    a.sb-home-view-all(href="#")
                        | Xem tất cả sân →

                .sb-home-filter

                    button Tất cả
                    button Sân 5 người
                    button Sân 7 người
                    button.active Sân nổi bật
                    button Có mái che

                .sb-home-featured-list

                    each item in [1,2,3]

                        .sb-home-field-card

                            .sb-home-field-card__image

                                .sb-home-badge VIP

                                .sb-home-badge.hot Nổi bật

                            .sb-home-field-card__body

                                h3 Đồng Đa Premium

                                p Khu vực Hà Nội

                                .sb-home-tags
                                    span Cỏ nhân tạo
                                    span 5 người
                                    span VIP

                                .sb-home-price
                                    strong 350k
                                    span / giờ

                                button Đặt ngay

                .sb-home-more
                    a(href="#") Xem thêm sân bóng →


        // SECTION 2
        section.sb-home-steps

            .sb-home-container

                .sb-home-heading.center

                    span.sb-home-subtitle
                        | ── Quy trình

                    h2
                        | Đặt sân trong 3
                        span  bước

                    p
                        | Không cần gọi điện. Không cần chờ xác nhận.

                .sb-home-step-list

                    .sb-home-step
                        .sb-home-step-number 1
                        h3 Tìm sân phù hợp
                        p Lọc theo khu vực, loại sân, giờ chơi.

                    .sb-home-step
                        .sb-home-step-number 2
                        h3 Chọn ngày & giờ
                        p Xem lịch trống thời gian thực.

                    .sb-home-step
                        .sb-home-step-number 3
                        h3 Thanh toán
                        p Ví điện tử hoặc chuyển khoản.

                    .sb-home-step
                        .sb-home-step-number 4
                        h3 Ra sân thi đấu
                        p Nhận mã đặt sân và check-in.


        // SECTION 3
        section.sb-home-location

            .sb-home-container

                .sb-home-heading

                    span.sb-home-subtitle
                        | ── Khu vực

                    h2
                        | Sân bóng khắp
                        span  Hà Nội

                    p
                        | Dễ dàng quản lý, luôn có sân GreenField gần đó.

                .sb-home-districts

                    each district in ['Cầu Giấy','Đống Đa','Tây Hồ','Long Biên','Thanh Xuân','Hoàn Kiếm','Hai Bà Trưng','Hoàng Mai','Xem tất cả']

                        .sb-home-district-card
                            .sb-home-district-icon
                            h4= district
                            span 12 sân
        // TESTIMONIAL
        section.sb-home-testimonial

            .sb-home-container

                .sb-home-heading.center

                    span.sb-home-subtitle
                        | ── Đánh giá

                    h2
                        | Người chơi
                        span  nói gì

                .sb-home-testimonial-list

                    each item in [1,2,3]

                        .sb-home-testimonial-card

                            .sb-home-quote
                                | "

                            p.sb-home-testimonial-content
                                | Từ khi dùng GreenField tôi không còn phải gọi điện hỏi còn sân không nữa. Đặt lịch 10 giây là xong ngay, rất tiện.

                            .sb-home-testimonial-footer

                                .sb-home-testimonial-user

                                    .sb-home-testimonial-avatar
                                        span NA

                                    .sb-home-testimonial-info
                                        h4 Nguyễn Văn A
                                        span Cầu Giấy, Hà Nội

                                .sb-home-testimonial-rating
                                    i.fa-solid.fa-star
                                    i.fa-solid.fa-star
                                    i.fa-solid.fa-star
                                    i.fa-solid.fa-star
                                    i.fa-solid.fa-star
