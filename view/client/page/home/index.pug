extends ../../layout/default.pug

block content

    // HERO
    section.gf-hero
        .gf-container.gf-hero__grid

            .gf-hero__content

                .gf-hero__tag
                    span.gf-dot
                    | Đặt sân trong 60 giây

                h1.gf-hero__title
                    | Tìm & Đặt
                    br
                    span Sân Bóng
                    br
                    | Ngay Hôm Nay

                p.gf-hero__desc
                    | Hơn 50 sân bóng chất lượng cao tại Hà Nội.
                    | Đặt lịch dễ dàng, thanh toán nhanh chóng.

                .gf-hero__actions
                    a.gf-btn.gf-btn--primary(
                        href="/booking"
                    )
                        | Đặt sân ngay

                    a.gf-btn.gf-btn--outline(
                        href="/field"
                    )
                        | Xem sân trống

                .gf-stats

                    .gf-stat
                        h3= statistics.totalFields + "+"
                        p Sân bóng

                    .gf-stat
                        h3= statistics.totalUsers + "+"
                        p Người dùng

                    .gf-stat
                        h3= statistics.totalBookings + "+"
                        p Lượt đặt sân

        // SECTION 1
        section.sb-home-featured

            .sb-home-container

                .sb-home-heading

                    span.sb-home-subtitle
                        | ── Sân nổi bật

                    h2
                        | Sân nổi bật
                        span  hôm nay

                    p
                        | Chọn từ hơn 50 sân được kiểm duyệt chất lượng

                    a.sb-home-view-all(href="/field")
                        | Xem tất cả sân →

                .sb-home-featured-list

                    each field in featuredFields

                        .sb-home-field-card

                            .sb-home-field-card__image

                                if field.image
                                    img(
                                        src=field.image[0]
                                        alt=field.name
                                    )

                                .sb-home-badge VIP

                                .sb-home-badge.hot Nổi bật

                            .sb-home-field-card__body

                                h3= field.name

                                p= field.address.titleAddress || "Hà Nội"

                                .sb-home-tags

                                    if field.grasstype
                                        span= field.grasstype

                                    if field.type
                                        span= field.type + " người"

                                    span VIP

                                .sb-home-price
                                    strong #{field.priceFormat}đ
                                    span / giờ

                                a(
                                    href=`/field/detail/${field.slug}`
                                )
                                    button Đặt ngay


        // SECTION 2
        section.sb-home-steps

            .sb-home-container

                .sb-home-heading.center

                    span.sb-home-subtitle
                        | ── Quy trình

                    h2
                        | Đặt sân trong 4
                        span  bước

                    p
                        | Không cần gọi điện. Không cần chờ xác nhận.

                .sb-home-step-list

                    .sb-home-step
                        .sb-home-step-number 1
                        h3 Tìm sân phù hợp
                        p Lọc theo khu vực, loại sân, giờ chơi.

                    .sb-home-step
                        .sb-home-step-number 2
                        h3 Chọn ngày & giờ
                        p Xem lịch trống thời gian thực.

                    .sb-home-step
                        .sb-home-step-number 3
                        h3 Thanh toán
                        p Ví điện tử hoặc chuyển khoản.

                    .sb-home-step
                        .sb-home-step-number 4
                        h3 Ra sân thi đấu
                        p Nhận mã đặt sân và check-in.


        // SECTION 3
        section.sb-home-location

            .sb-home-container

                .sb-home-heading

                    span.sb-home-subtitle
                        | ── Khu vực

                    h2
                        | Sân bóng khắp
                        span  Hà Nội

                    p
                        | Dễ dàng quản lý, luôn có sân GreenField gần đó.

                .sb-home-districts

                    each area in areas

                        .sb-home-district-card

                            .sb-home-district-icon
                                i.fa-solid.fa-location-dot

                            h4= area._id.titleAddress.split(", ").at(-2)

                            span= area.totalFields + " sân"
        // TESTIMONIAL
        section.sb-home-testimonial

            .sb-home-container

                .sb-home-heading.center

                    span.sb-home-subtitle
                        | ── Đánh giá

                    h2
                        | Người chơi
                        span  nói gì

                .sb-home-testimonial-list

                    each item in reviewRating

                        .sb-home-testimonial-card

                            .sb-home-quote
                                | "

                            p.sb-home-testimonial-content
                                | #{item.comment}

                            .sb-home-testimonial-footer

                                .sb-home-testimonial-user

                                    .sb-home-testimonial-avatar
                                        span NA

                                    .sb-home-testimonial-info
                                        h4 #{item.user.userName}

                                .sb-home-testimonial-rating
                                    i.fa-solid.fa-star
                                    i.fa-solid.fa-star
                                    i.fa-solid.fa-star
                                    i.fa-solid.fa-star
                                    i.fa-solid.fa-star
